{
  "name": "blockchain-election-dapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "compile": "set APPDATA=%cd%\\.hardhat-data&& set LOCALAPPDATA=%cd%\\.hardhat-data&& hardhat compile",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "set APPDATA=%cd%\\.hardhat-data&& set LOCALAPPDATA=%cd%\\.hardhat-data&& hardhat test",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:all": "npm test && npm run test:frontend",
    "deploy:sepolia": "set APPDATA=%cd%\\.hardhat-data&& set LOCALAPPDATA=%cd%\\.hardhat-data&& hardhat run scripts/deploy.cjs --network sepolia"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "ethers": "^6.16.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@openzeppelin/contracts": "^5.6.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "hardhat": "^2.28.0",
    "jsdom": "^29.1.1",
    "vite": "^8.0.4",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.5"
  }
}
